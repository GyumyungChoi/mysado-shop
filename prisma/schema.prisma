// mysado-shop / Prisma 6 기준
// Phase 2: 인증(Better Auth) + 행동 로그

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  phoneNumber   String?   @map("phone_number")  // 추가(26.07.11.토)
  role          String    @default("user")      // "user" | "admin" — Phase 5 추가(26.07.18.토)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  productViews  ProductViewLog[]   // ← 추가
  searchLogs    SearchLog[]        // ← 추가
  cartItems     CartItem[]         // ← Phase 4 추가
  orders        Order[]            // ← Phase 4 추가

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── 행동 로그 (AI 개인화 추천용 데이터 수집) ───

model ProductViewLog {
  id        Int      @id @default(autoincrement())
  userId    String?  // 비로그인 조회도 기록 (null 허용)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?  // 비로그인 방문자 구분용 (쿠키 기반, 추후 활용)
  
  productId String?  // 상품 삭제 시 SetNull로 로그 보존 (Phase 3에서 FK 전환 완료)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  viewedAt  DateTime @default(now())

  @@index([userId, viewedAt])
  @@index([productId])
  @@map("product_view_log")
}

model SearchLog {
  id          Int      @id @default(autoincrement())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  keyword     String
  resultCount Int?     // 검색 결과 개수 (0이면 "없는 상품 수요" 신호!), 검색했는데 결과가 0인 키워드는 "손님이 찾는데 우리 가게에 없는 상품" 목록
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([keyword])
  @@map("search_log")
}

model Product {
  id               String   @id                      // prod-001 (URL/로그 호환)
  sku              String?                           // null 50건, @unique 불가
  categoryId       String   @map("category_id")
  categoryName     String   @map("category_name")
  name             String
  price            Int
  discountedPrice  Int?     @map("discounted_price")
  stock            Int      @default(0) @map("stock_quantity")
  status           String   @default("SALE")         // SALE/OUTOFSTOCK/SUSPENSION
  isVisible        Boolean  @default(true) @map("is_active")
  description      String   @default("")             // AI 설명 생성용
  detailHtml       String   @default("") @map("detail_html")
  images           String[]
  brand            String
  manufacturerName String   @default("") @map("manufacturer_name")
  modelName        String   @default("") @map("model_name")
  tags             String[]
  deliveryFee      Int      @default(0) @map("delivery_fee")
  returnFee        Int      @default(0) @map("return_fee")
  exchangeFee      Int      @default(0) @map("exchange_fee")
  viewLogs ProductViewLog[]
  cartItems  CartItem[]    // ← Phase 4 추가
  orderItems OrderItem[]   // ← Phase 4 추가
  sortOrder        Int      @map("sort_order")

  // ── 네이버 채널 필드 (향후 ProductChannel 분리 예정) ──
  originProductNo  String   @map("origin_product_no")
  channelProductNo String   @map("channel_product_no")
  naverCategoryId  String   @map("naver_category_id")
  naverWholeCategoryId String @map("naver_whole_category_id")
  smartstoreUrl    String   @map("smartstore_url")

  registeredAt     DateTime @map("registered_at")    // 스토어 등록일 (JSON created_at)
  channelModifiedAt DateTime @map("channel_modified_at") // JSON modified_at
  createdAt        DateTime @default(now()) @map("created_at")  // DB 삽입 시각
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("product")
}

// ─── Phase 4: 장바구니 / 주문 / 결제 ───

enum OrderStatus {
  PENDING     // 주문 생성 (결제 전)
  PAID        // 결제 승인 완료
  PREPARING   // 상품 준비 중
  SHIPPING    // 배송 중
  DONE        // 배송 완료
  FAILED      // 결제 실패
  CANCELED    // 취소
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  productId String   @map("product_id")           // Product.id = "prod-001" 형식
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])   // 같은 상품은 한 행, 수량만 증가
  @@map("cart_item")
}

model Order {
  id             String      @id @default(cuid())  // 토스 orderId로 그대로 사용 (6~64자 규격 충족)
  userId         String      @map("user_id")       // NOT NULL — 탈퇴는 Soft Delete로만 (Restrict가 하드삭제 차단)
  status         OrderStatus @default(PENDING)
  totalAmount    Int         @map("total_amount")  // 원 단위 정수, confirm 시 amount 재검증 기준

  // 배송지 스냅샷 (주문 시점 고정)
  recipientName  String      @map("recipient_name")
  recipientPhone String      @map("recipient_phone")
  zipCode        String      @map("zip_code")
  address1       String
  address2       String?
  deliveryMemo   String?     @map("delivery_memo")

  // 토스 결제 결과
  paymentKey     String?     @unique @map("payment_key")   // DB 레벨 중복 승인 차단
  paidAt         DateTime?   @map("paid_at")

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  paymentLogs PaymentLog[]

  @@index([userId, createdAt])   // 마이페이지 "내 주문 최신순" 대비
  @@map("orders")                // 단수 order는 SQL 예약어 → 복수형 예외
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String  @map("order_id")
  productId   String? @map("product_id")

  // ★ 주문 시점 스냅샷 (상품 삭제/가격 변경과 무관하게 보존)
  productName String  @map("product_name")
  unitPrice   Int     @map("unit_price")    // 실결제 단가 (discountedPrice ?? price)
  quantity    Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_item")
}

model PaymentLog {
  id         Int      @id @default(autoincrement())
  orderId    String   @map("order_id")
  type       String                              // 코드 레벨 as const 상수 + UNKNOWN 파서로 관리
  paymentKey String?  @map("payment_key")
  payload    Json                                // 토스 요청/응답 원문 그대로
  createdAt  DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payment_log")
}